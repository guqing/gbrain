{
  "name": "@guqings/exo",
  "version": "0.7.0",
  "description": "Your exocortex. Ingest ChatGPT exports, PDFs, and files into a searchable knowledge base. Hybrid FTS5 + vector search. LLM-compiled knowledge pages. MCP server for Claude Code and Cursor.",
  "type": "module",
  "bin": {
    "exo": "./bin/exo.ts"
  },
  "workspaces": [
    "ui"
  ],
  "scripts": {
    "dev": "bun run src/cli.ts",
    "ui:dev": "bun run scripts/ui-dev.ts",
    "ui:dev:web": "bun run --cwd ui dev",
    "ui:generate": "bun run scripts/generate-ui-assets.ts",
    "ui:build": "bun run --cwd ui build && bun run ui:generate",
    "build": "bun run ui:build && bun build --compile --minify src/cli.ts --outfile bin/exo",
    "prepublishOnly": "bun run build",
    "test": "bun test",
    "pack:check": "npm pack --dry-run"
  },
  "files": [
    "bin/exo.ts",
    "src/",
    "src/ui/generated.ts",
    "!src/tests/"
  ],
  "engines": {
    "bun": ">=1.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "exocortex",
    "second-brain",
    "personal-knowledge",
    "pkm",
    "chatgpt-export",
    "mcp-server",
    "claude-code",
    "rag",
    "sqlite",
    "vector-search",
    "cli",
    "gbrain"
  ],
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.85.0",
    "@ltd/j-toml": "^1.38.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "citty": "^0.2.2",
    "gray-matter": "^4.0.3",
    "mammoth": "^1.12.0",
    "openai": "^6.33.0",
    "unpdf": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5"
  }
}
