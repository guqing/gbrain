{
  "name": "@guqings/gbrain",
  "version": "0.3.0",
  "description": "Personal knowledge brain — CLI + MCP server. SQLite + FTS5 + vector search.",
  "type": "module",
  "bin": {
    "gbrain": "./bin/gbrain.ts"
  },
  "scripts": {
    "dev": "bun run src/cli.ts",
    "build": "bun build --compile --minify src/cli.ts --outfile bin/gbrain",
    "test": "bun test"
  },
  "files": [
    "bin/gbrain.ts",
    "src/",
    "!src/tests/"
  ],
  "engines": {
    "bun": ">=1.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "knowledge-base",
    "mcp",
    "sqlite",
    "cli",
    "rag"
  ],
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.85.0",
    "@ltd/j-toml": "^1.38.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "citty": "^0.2.2",
    "gray-matter": "^4.0.3",
    "openai": "^6.33.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5"
  }
}
